# Real order storage and bans
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_public_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Required admin credentials for /admin
ADMIN_DASHBOARD_USER=your_admin_username
ADMIN_DASHBOARD_KEY=your_admin_password

# Stripe checkout for shipping card orders
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
# Add after you create the Stripe webhook that points to /api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Optional staging/demo checkout mode for local testing only
# NEXT_PUBLIC_CHECKOUT_DEMO_MODE=true
# CHECKOUT_DEMO_MODE=true

# Primary inbox
MAIL_TO=moneygrowontrees80@gmail.com
CONTACT_TO_EMAIL=moneygrowontrees80@gmail.com
ORDER_ALERT_TO_EMAIL=moneygrowontrees80@gmail.com
ENABLE_CUSTOMER_ORDER_EMAIL=true

# Preferred fallback mail setup: Gmail SMTP
GMAIL_USER=moneygrowontrees80@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password

# Optional generic SMTP instead of Gmail
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=username
# SMTP_PASS=password
# SMTP_FROM=Home Grown Money <moneygrowontrees80@gmail.com>

# Optional Resend fallback
# RESEND_API_KEY=re_xxx
# RESEND_FROM=Home Grown Money <onboarding@resend.dev>

# Optional order text alerts
# TWILIO_ACCOUNT_SID=ACxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxx
# TWILIO_PHONE_NUMBER=+16610000000
# ALERT_PHONE_1=+16610000000
# ALERT_PHONE_2=
# ALERT_PHONE_3=
# ALERT_PHONE_4=
# ALERT_PHONE_5=
# ALERT_PHONE_6=
